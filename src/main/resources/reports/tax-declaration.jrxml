<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="tax-declaration"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30"
              language="groovy">

    <!-- パラメータ定義 -->
    <parameter name="declarationId" class="java.lang.String">
        <defaultValueExpression><![CDATA["N/A"]]></defaultValueExpression>
    </parameter>
    <parameter name="obligorName" class="java.lang.String">
        <defaultValueExpression><![CDATA["（未設定）"]]></defaultValueExpression>
    </parameter>
    <parameter name="targetYearMonth" class="java.lang.String">
        <defaultValueExpression><![CDATA["（未設定）"]]></defaultValueExpression>
    </parameter>
    <parameter name="taxableGuestCount" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[0]]></defaultValueExpression>
    </parameter>
    <parameter name="taxRate" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[0]]></defaultValueExpression>
    </parameter>
    <parameter name="totalTaxAmount" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[0]]></defaultValueExpression>
    </parameter>

    <!-- タイトルバンド -->
    <title>
        <band height="80">
            <!-- 申告書タイトル -->
            <staticText>
                <reportElement x="0" y="10" width="535" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="20" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[宿泊税申告書]]></text>
            </staticText>
            <!-- 区切り線 -->
            <line>
                <reportElement x="0" y="58" width="535" height="1"/>
            </line>
        </band>
    </title>

    <!-- 詳細バンド -->
    <detail>
        <band height="300">

            <!-- 申告ID -->
            <staticText>
                <reportElement x="0" y="20" width="150" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[申告ID]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="20" width="375" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{declarationId}]]></textFieldExpression>
            </textField>

            <!-- 特別徴収義務者名 -->
            <staticText>
                <reportElement x="0" y="54" width="150" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[特別徴収義務者名]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="54" width="375" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{obligorName}]]></textFieldExpression>
            </textField>

            <!-- 申告年月 -->
            <staticText>
                <reportElement x="0" y="88" width="150" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[申告年月]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="88" width="375" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{targetYearMonth}]]></textFieldExpression>
            </textField>

            <!-- 区切り線 -->
            <line>
                <reportElement x="0" y="122" width="535" height="1"/>
            </line>

            <!-- 課税対象宿泊数 -->
            <staticText>
                <reportElement x="0" y="134" width="150" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[課税対象宿泊数]]></text>
            </staticText>
            <textField pattern="#,##0">
                <reportElement x="160" y="134" width="200" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{taxableGuestCount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="365" y="134" width="40" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[ 泊]]></text>
            </staticText>

            <!-- 設定税額 -->
            <staticText>
                <reportElement x="0" y="168" width="150" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[設定税額（円/泊）]]></text>
            </staticText>
            <textField pattern="#,##0">
                <reportElement x="160" y="168" width="200" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{taxRate}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="365" y="168" width="40" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="11"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[ 円]]></text>
            </staticText>

            <!-- 区切り線 -->
            <line>
                <reportElement x="0" y="202" width="535" height="1"/>
            </line>

            <!-- 納入金額（合計） -->
            <staticText>
                <reportElement x="0" y="214" width="150" height="30"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="13" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[納入金額（合計）]]></text>
            </staticText>
            <textField pattern="#,##0">
                <reportElement x="160" y="214" width="200" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="13" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalTaxAmount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="365" y="214" width="40" height="30"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="IPAexMincho" size="13" isBold="true"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[ 円]]></text>
            </staticText>

        </band>
    </detail>

    <!-- ページフッター -->
    <pageFooter>
        <band height="30">
            <textField>
                <reportElement x="0" y="5" width="535" height="20"/>
                <textElement textAlignment="Right">
                    <font fontName="IPAexMincho" size="9"
                          pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA["- " + $V{PAGE_NUMBER} + " -"]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
